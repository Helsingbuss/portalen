                  </p>
                </div>
              </div>

              <div className="rounded-2xl border border-slate-300 p-5">
                <TopField label="Avtalsnummer" value="Skapas automatiskt" readOnly />
                <TopField
                  label="Avtalsdatum"
                  type="date"
                  value={form.agreement_date}
                  onChange={(value) => update("agreement_date", value)}
                />
                <TopField
                  label="Giltigt från"
                  type="date"
                  value={form.valid_from}
                  onChange={(value) => update("valid_from", value)}
                />
                <TopField
                  label="Giltigt till"
                  type="date"
                  value={form.valid_until}
                  onChange={(value) => update("valid_until", value)}
                />

                <div className="mt-5 grid grid-cols-2 gap-3">
                  <SelectField
                    label="Typ"
                    value={form.agreement_type}
                    onChange={(value) => update("agreement_type", value)}
                    options={[
                      ["framework", "Ramavtal"],
                      ["company", "Företagsavtal"],
                      ["association", "Föreningsavtal"],
                      ["agent", "Agentavtal"],
                      ["customer_price", "Kundpris"],
