}

function TopField({
  label,
  value,
  onChange,
  type = "text",
  readOnly,
}: {
  label: string;
  value: string;
  onChange?: (value: string) => void;
  type?: string;
  readOnly?: boolean;
}) {
  return (
    <label className="mb-4 grid grid-cols-[120px_1fr] items-center gap-3 text-xs font-black uppercase text-[#082a5e]">
      <span>{label}</span>
      <input
        type={type}
        value={value}
        readOnly={readOnly}
        onChange={(event) => onChange?.(event.target.value)}
        className="border-0 border-b border-slate-300 bg-transparent px-1 py-2 text-sm font-semibold normal-case text-slate-800 outline-none focus:border-[#082a5e]"
      />
    </label>
  );
}

function SelectField({
  label,
  value,
  onChange,
  options,
}: {
  label: string;
  value: string;
  onChange: (value: string) => void;
  options: [string, string][];
