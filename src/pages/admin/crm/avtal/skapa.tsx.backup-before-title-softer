function formatDate(date: string) {
  if (!date) return "";
  try {
    return new Intl.DateTimeFormat("sv-SE", {
      day: "numeric",
      month: "long",
      year: "numeric",
    }).format(new Date(date + "T00:00:00"));
  } catch {
    return date;
  }
}

export default function CreateCrmAvtalPage() {
  const router = useRouter();
  const [form, setForm] = useState<FormState>(emptyForm);
  const [saving, setSaving] = useState(false);
  const [error, setError] = useState("");

  const customerDisplayName = useMemo(() => {
    return form.company_name || form.customer_name || "Kund";
  }, [form.company_name, form.customer_name]);

  function update<K extends keyof FormState>(key: K, value: FormState[K]) {
    setForm((prev) => ({ ...prev, [key]: value }));
  }

  async function saveAgreement() {
    try {
      setSaving(true);
      setError("");

      const res = await fetch("/api/admin/crm/avtal", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(form),
      });

      const json = await res.json().catch(() => ({}));

      if (!res.ok || !json.ok) {
        throw new Error(json.error || "Kunde inte spara avtalet.");
      }

      router.push("/admin/crm/avtal/" + encodeURIComponent(json.agreement.id));
    } catch (err: any) {
      setError(err?.message || "Kunde inte spara avtalet.");
    } finally {
      setSaving(false);
    }
  }

