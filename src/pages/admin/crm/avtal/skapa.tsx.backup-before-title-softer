              <ContractArea label="Särskilda önskemål / övrig information" value={form.special_requests} onChange={(v) => update("special_requests", v)} rows={3} />
            </AgreementSection>

            <div className="mt-8 grid gap-6 lg:grid-cols-2">
              <AgreementSection number="2" title="Avtalsperiod & bindningstid" compact>
                <div className="grid gap-4 sm:grid-cols-2">
                  <TopField label="Från" type="date" value={form.valid_from} onChange={(v) => update("valid_from", v)} />
                  <TopField label="Till" type="date" value={form.valid_until} onChange={(v) => update("valid_until", v)} />
                </div>

                <ContractLine label="Minsta bindningstid, månader" value={form.min_commitment_months} onChange={(v) => update("min_commitment_months", v)} />
                <ContractLine label="Uppsägningstid, månader" value={form.notice_months} onChange={(v) => update("notice_months", v)} />
                <ContractLine label="Förlängning, månader" value={form.extension_months} onChange={(v) => update("extension_months", v)} />

                <p className="rounded-xl bg-slate-50 p-4 text-xs leading-6 text-slate-600">
                  Avtalet är bindande under avtalad bindningstid. Uppsägning kan endast ske enligt villkoren ovan.
                </p>
              </AgreementSection>

              <AgreementSection number="3" title="Pris & betalningsvillkor" compact>
                <div className="grid gap-4 sm:grid-cols-3">
                  <ContractLine label="Rabatt %" value={form.discount_percent} onChange={(v) => update("discount_percent", v)} />
                  <ContractLine label="Fast pris" value={form.fixed_price} onChange={(v) => update("fixed_price", v)} />
                  <ContractLine label="Valuta" value={form.currency} onChange={(v) => update("currency", v)} />
                </div>

                <ContractLine label="Faktureringsintervall" value={form.invoicing_interval} onChange={(v) => update("invoicing_interval", v)} />
                <ContractArea label="Betalningsvillkor" value={form.payment_terms} onChange={(v) => update("payment_terms", v)} rows={4} />
                <ContractArea label="Övrigt" value={form.payment_other} onChange={(v) => update("payment_other", v)} rows={3} />
              </AgreementSection>
            </div>

            <div className="mt-8 grid gap-6 xl:grid-cols-3">
              <AgreementTextBlock
                number="4"
                title="Avbokning / ändringar"
                value={form.cancellation_terms}
                onChange={(v) => update("cancellation_terms", v)}
              />

              <AgreementTextBlock
                number="5"
                title="Parternas ansvar"
                value={"Helsingbuss ansvarar för:\n" + form.hb_responsibility + "\n\nKunden ansvarar för:\n" + form.customer_responsibility}
                onChange={(v) => {
                  const parts = v.split("\n\nKunden ansvarar för:\n");
                  const hb = parts[0]?.replace("Helsingbuss ansvarar för:\n", "") || "";
                  const customer = parts[1] || form.customer_responsibility;
                  update("hb_responsibility", hb);
                  update("customer_responsibility", customer);
                }}
              />

              <AgreementTextBlock
                number="6"
                title="Övriga villkor"
                value={
                  "Force majeure:\n" +
                  form.force_majeure_terms +
                  "\n\nPersonuppgifter / GDPR:\n" +
                  form.gdpr_terms +
                  "\n\nÄndringar:\n" +
                  form.change_terms +
                  (form.extra_terms ? "\n\nExtra villkor:\n" + form.extra_terms : "")
                }
                onChange={(v) => update("extra_terms", v)}
                helper="Här kan du lägga egna extra villkor. Standardvillkor sparas separat."
              />
            </div>

            <div className="mt-10 grid gap-6 lg:grid-cols-[1fr_1fr_220px]">
              <AgreementBox title="Helsingbuss AB">
                <ContractLine label="Ort & datum" value={form.hb_sign_place_date} onChange={(v) => update("hb_sign_place_date", v)} />
                <ContractLine label="Namnförtydligande" value={form.hb_sign_name} onChange={(v) => update("hb_sign_name", v)} />
                <ContractLine label="Befattning" value={form.hb_sign_title} onChange={(v) => update("hb_sign_title", v)} />
                <SignatureLine />
              </AgreementBox>

              <AgreementBox title="Kund">
                <ContractLine label="Ort & datum" value={form.customer_sign_place_date} onChange={(v) => update("customer_sign_place_date", v)} />
                <ContractLine label="Namnförtydligande" value={form.customer_sign_name} onChange={(v) => update("customer_sign_name", v)} />
                <ContractLine label="Befattning" value={form.customer_sign_title} onChange={(v) => update("customer_sign_title", v)} />
                <SignatureLine />
              </AgreementBox>

              <div className="rounded-2xl bg-[#eef4fb] p-5 text-[#082a5e]">
                <div className="text-lg font-black">Signering</div>
                <p className="mt-3 text-sm leading-6">
                  Vänligen signera och returnera avtalet. Avtalet signeras av båda parter.
                </p>
              </div>
            </div>

            <div className="mt-10 flex flex-wrap items-center justify-between gap-4 border-t border-slate-200 pt-5 text-sm text-[#082a5e]">
              <div>Järnvägsgatan 19 · 252 24 Helsingborg</div>
              <div>042-12 33 00</div>
              <div>info@helsingbuss.se</div>
              <div>helsingbuss.se</div>
            </div>
          </section>

          <div className="mx-auto mt-6 flex max-w-[1180px] justify-end gap-3">
            <Link
              href="/admin/crm/avtal"
              className="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-[#194C66] shadow-sm transition hover:bg-slate-50"
            >
              Avbryt
            </Link>

            <button
              type="button"
              onClick={saveAgreement}
              disabled={saving}
              className="inline-flex items-center justify-center rounded-xl bg-[#00645d] px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[#004f49] disabled:cursor-not-allowed disabled:opacity-60"
            >
              {saving ? "Sparar..." : "Spara avtal"}
            </button>
          </div>
        </main>
      </div>
    </>
  );
}

function AgreementBox({
  title,
  children,
}: {
  title: string;
  children: React.ReactNode;
}) {
  return (
    <section className="overflow-hidden rounded-2xl border border-slate-300 bg-white">
      <div className="bg-[#082a5e] px-4 py-3 text-sm font-black uppercase tracking-wide text-white">
        {title}
      </div>
      <div className="divide-y divide-slate-200">{children}</div>
    </section>
  );
}

function AgreementSection({
  number,
  title,
  children,
  compact,
}: {
  number: string;
  title: string;
  children: React.ReactNode;
  compact?: boolean;
}) {
  return (
    <section className={compact ? "mt-0" : "mt-8"}>
      <h2 className="mb-3 text-lg font-black uppercase tracking-tight text-[#082a5e]">
        {number}. {title}
      </h2>

      <div className="overflow-hidden rounded-2xl border border-slate-300 bg-white p-0">
        <div className="space-y-0 divide-y divide-slate-200 p-4">{children}</div>
      </div>
    </section>
  );
}

function AgreementTextBlock({
  number,
  title,
  value,
  onChange,
  helper,
}: {
  number: string;
  title: string;
  value: string;
  onChange: (value: string) => void;
  helper?: string;
}) {
  return (
    <section>
      <h2 className="mb-3 text-base font-black uppercase tracking-tight text-[#082a5e]">
        {number}. {title}
      </h2>

      <textarea
        value={value}
