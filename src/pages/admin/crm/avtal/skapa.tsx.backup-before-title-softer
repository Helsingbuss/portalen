                <ContractLine label="Organisationsnummer" value={form.hb_org_number} onChange={(v) => update("hb_org_number", v)} />
                <ContractLine label="Adress" value={form.hb_address} onChange={(v) => update("hb_address", v)} />
                <ContractLine label="Kontaktperson" value={form.hb_contact_person} onChange={(v) => update("hb_contact_person", v)} />
                <ContractLine label="E-post" value={form.hb_email} onChange={(v) => update("hb_email", v)} />
                <ContractLine label="Telefon" value={form.hb_phone} onChange={(v) => update("hb_phone", v)} />
              </AgreementBox>

              <AgreementBox title="Part 2 – Kund">
                <ContractLine label="Företagsnamn / Kundnamn" value={form.company_name} onChange={(v) => update("company_name", v)} />
                <ContractLine label="Organisationsnummer" value={form.org_number} onChange={(v) => update("org_number", v)} />
                <ContractLine label="Personnummer" value={form.customer_person_number} onChange={(v) => update("customer_person_number", v)} />
                <ContractLine label="Adress" value={form.customer_address} onChange={(v) => update("customer_address", v)} />
                <ContractLine label="Kontaktperson" value={form.contact_person} onChange={(v) => update("contact_person", v)} />
                <ContractLine label="E-post" value={form.email} onChange={(v) => update("email", v)} />
                <ContractLine label="Telefon" value={form.phone} onChange={(v) => update("phone", v)} />
              </AgreementBox>
            </div>

            <AgreementSection number="1" title="Avtalets omfattning">
              <ContractLine label="Tjänst / Uppdrag" value={form.service_task} onChange={(v) => update("service_task", v)} />
