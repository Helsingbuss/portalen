{
    "compilerOptions":  {
                            "target":  "ES2017",
                            "lib":  [
                                        "dom",
                                        "dom.iterable",
                                        "esnext"
                                    ],
                            "allowJs":  true,
                            "skipLibCheck":  true,
                            "strict":  false,
                            "noEmit":  true,
                            "esModuleInterop":  true,
                            "module":  "esnext",
                            "moduleResolution":  "bundler",
                            "resolveJsonModule":  true,
                            "isolatedModules":  true,
                            "jsx":  "react-jsx",
                            "incremental":  true,
                            "baseUrl":  ".",
                            "paths":  {
                                          "@/*":  [
                                                      "src/*"
                                                  ],
                                          "react-native":  [
                                                               "src/stubs/react-native.ts"
                                                           ],
                                          "expo-router":  [
                                                              "src/stubs/expo-router.ts"
                                                          ],
                                          "expo-constants":  [
                                                                 "src/stubs/expo-constants.ts"
                                                             ]
                                      },
                            "plugins":  [
                                            {
                                                "name":  "next"
                                            }
                                        ]
                        },
    "include":  [
                    "next-env.d.ts",
                    "**/*.ts",
                    "**/*.tsx",
                    ".next/types/**/*.ts"
                ],
    "exclude":  [
                    "node_modules",
                    "mobile",
                    "mobile-app",
                    "apps/hbshuttle/node_modules"
                ]
}
